# Required external client legacy database connection. Copy this file to
# .env.client and provide credentials locally; .env.client is ignored by Git.
ConnectionStrings__LegacySource='Server=tcp:<server>,1433;Initial Catalog=<database>;Persist Security Info=False;User ID=<read-only-user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30'
